# StartupIQ Environment Configuration

# LLM Provider
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Default Model
MODEL=google/gemma-4-26b-a4b-it:free

# LLM Configuration
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_DELAY=1.0
LLM_RETRY_BACKOFF=2.0

# Application
LOG_LEVEL=INFO

# Project Metadata
PROJECT_NAME=StartupIQ
PROJECT_VERSION=1.0.0
PROJECT_DESCRIPTION=An AI-powered Startup Idea Validation Platform